# PolyEdge — Environment Configuration
#
# Database (used by all services)
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket_secret
POSTGRES_DB=polymarket_tracker
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# Trading bot credentials (only needed by trading service)
PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
PROXY_WALLET=
EOA_ADDRESS=

# Optional proxy
PROXY_URL=

# Trading parameters
BET_SIZE_USD=1.5
DAILY_LOSS_LIMIT=60.0
LOOP_INTERVAL=5
STRATEGY_MOMENTUM_ENABLED=true

# Polygon RPC (for redemption)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
