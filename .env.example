# PolyEdge — Environment Configuration
#
# Database (used by all services)
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket_secret
POSTGRES_DB=polymarket_tracker
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# Trading bot credentials (only needed by trading service)
PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
PROXY_WALLET=
EOA_ADDRESS=

# Relayer API (recommended for gasless redemption / CTF ops)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
RELAYER_BASE_URL=https://relayer-v2.polymarket.com
REDEEM_ONCHAIN_FALLBACK=true

# Optional proxy
PROXY_URL=

# Core dry-run mode
CORE_DEBUG_MODE=false
BINANCE_WS_URL=wss://stream.binance.com:9443
BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_TRACKED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT
BINANCE_BACKFILL_LOOKBACK_SECONDS=120
BINANCE_STALE_DATA_THRESHOLD_SECONDS=3

# Trading parameters
BET_SIZE_USD=1.5
DAILY_LOSS_LIMIT=60.0
LOOP_INTERVAL=5
STRATEGY_MOMENTUM_ENABLED=true

# Polygon RPC (only used by the direct on-chain redemption fallback)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Dashboard (Next.js)
DASHBOARD_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
DASHBOARD_PASSWORD=
